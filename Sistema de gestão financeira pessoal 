Data obterDataAtual() {
    Data d;
    time_t agora = time(0);
    tm *tempo = localtime(&agora);
    d.dia = tempo->tm_mday;
    d.mes = tempo->tm_mon + 1;
    d.ano = tempo->tm_year + 1900;
    return d;
}

void mostrarData(Data d) {
    cout << d.dia << "/" << d.mes << "/" << d.ano;
}

