void registrarGastosDia() {
    HistoricoDia dia;
    dia.data = obterDataAtual();
    dia.receita = 0;
    dia.totalGastos = 0;
    dia.gastosNecessarios = 0;
    dia.gastosDesnecessarios = 0;
    dia.valorPoupadoHoje = 0;

    cout << "\n==============================";
    cout << "\n REGISTO DIARIO";
    cout << "\n==============================\n";
    cout << "Deseja continuar? (1 - Sim / 0 - Voltar ao Menu): ";
    int voltar;
    cin >> voltar;
    if(voltar == 0) return;
    
    cout << "Que dia do ciclo/mes e hoje? (Ex: 1, 2, 15...): ";
    cin >> dia.diaDoCiclo;

    cout << "Data do Sistema: ";
    mostrarData(dia.data);

    int quantidade;
    cout << "\n\nQuantos gastos teve hoje? (Ou digite 0 para pular para poupancas): ";
    cin >> quantidade;
    
    for(int i = 1; i <= quantidade; i++) {
        Gasto g;
        g.data = dia.data;

        cout << "\n----------------------";
        cout << "\nGASTO " << i;
        cout << "\n----------------------\n";
        
        cin.ignore(10000, '\n'); 
        cout << "Descricao: ";
        getline(cin, g.descricao);

        g.categoria = escolherCategoria();
        cout << "Valor (MT): ";
        cin >> g.valor;

        int opcao;
        cout << "\nFoi necessario?\n";
        cout << "1 - Sim\n";
        cout << "2 - Nao\n";
        cout << "Escolha: ";
        cin >> opcao;

        if(opcao == 1) {
            g.necessario = true;
            dia.gastosNecessarios += g.valor;
        } else {
            g.necessario = false;
            dia.gastosDesnecessarios += g.valor;
        }

        cout << "\nEra prioritario?\n";
        cout << "1 - Sim\n";
        cout << "2 - Nao\n";
        cout << "Escolha: ";
        cin >> opcao;

        if(opcao == 1) g.prioritario = true;
        else g.prioritario = false;

        usuario.saldoAtual -= g.valor;
        dia.totalGastos += g.valor;
        dia.gastos.push_back(g);

        cout << "\nSaldo atual: " << usuario.saldoAtual << " MT\n";
    }

    float poupancaHoje = 0;
    cout << "\n==============================";
    cout << "\n DEPOSITO EM POUPANCA";
    cout << "\n==============================\n";
    cout << "Saldo disponivel para poupar: " << usuario.saldoAtual << " MT\n";
    cout << "Quanto deseja poupar e guardar hoje? (MT) [Ou digite 0 para pular]: ";
    cin >> poupancaHoje;

    if(poupancaHoje > 0 && poupancaHoje <= usuario.saldoAtual) {
        usuario.saldoAtual -= poupancaHoje;
        usuario.poupancaAcumulada += poupancaHoje;
        dia.valorPoupadoHoje = poupancaHoje;
        cout << "Sucesso! " << poupancaHoje << " MT foram transferidos para a sua Conta Poupança.\n";
    } else if (poupancaHoje > usuario.saldoAtual) {
        cout << "Aviso: Nao tem saldo suficiente para poupar esse valor hoje.\n";
    }

    dia.avaliacao = avaliarDia(dia);
    historico.push_back(dia);
    guardarHistorico(dia);
    guardarDados();
    mostrarFeedback(dia);
    pausa();
}

string avaliarDia(HistoricoDia dia) {
    float total = dia.totalGastos;
    if(total == 0) return "Sem gastos";

    if(usuario.saldoAtual < 0) return "Dia critico (Saldo Negativo)";
    
    if(dia.gastosDesnecessarios > dia.gastosNecessarios) {
        return "Dia desequilibrado (Excesso de superfluos)";
    }

    float percentagemNecessaria = (dia.gastosNecessarios * 100) / total;
    if(percentagemNecessaria >= 70) return "Dia produtivo";
    
    return "Dia equilibrado";
}

void mostrarFeedback(HistoricoDia dia) {
    cout << "\n==============================";
    cout << "\n FEEDBACK FINANCEIRO (DIA " << dia.diaDoCiclo << ")";
    cout << "\n==============================\n";
    cout << "Resultado: " << dia.avaliacao << endl;

    if(dia.avaliacao == "Dia produtivo") {
        cout << "\nExcelente comportamento! Controlou os seus impulsos e focou-se no essencial.\n";
        cout << "Poupança de hoje: " << dia.valorPoupadoHoje << " MT guardados com sucesso.\n";
    } else if(dia.avaliacao == "Dia desequilibrado (Excesso de superfluos)") {
        cout << "\n[ALERTA DE COMPORTAMENTO]\n";
        cout << "Hoje voce gastou muito dinheiro com besteiras ou despesas desnecessarias (" << dia.gastosDesnecessarios << " MT).\n";
        cout << "CONSELHO: Evite repetir estas praticas nos proximos dias. Se continuar assim, podera comprometer o orçamento do mes!\n";
    } else if(usuario.saldoAtual < 0) {
        cout << "\n[SITUAÇAO PERIGOSA]\n";
        cout << "O seu saldo ficou negativo! Corte imediatamente qualquer gasto nao-essencial.\n";
    } else {
        cout << "\nAs suas finanças estao estaveis, mas lembre-se de monitorar despesas pequenas que parecem inofensivas.\n";
    }
}

