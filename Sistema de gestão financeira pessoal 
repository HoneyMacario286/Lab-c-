void relatorioMensal() {
    float totalGasto = 0;
    float totNecessario = 0;
    float totNaoNecessario = 0;
    int dias = historico.size();

    for(size_t i = 0; i < historico.size(); i++) {
        totalGasto += historico[i].totalGastos;
        totNecessario += historico[i].gastosNecessarios;
        totNaoNecessario += historico[i].gastosDesnecessarios;
    }

    cout << "\n==============================";
    cout << "\n RELATORIO GERAL";
    cout << "\n==============================\n";
    cout << "Utilizador: " << usuario.nome;
    cout << "\nRenda inicial: " << usuario.rendaBase << " MT";
    cout << "\nTotal gasto: " << totalGasto << " MT";
    cout << "\nGastos necessarios acumulados: " << totNecessario << " MT";
    cout << "\nGastos desnecessarios acumulados: " << totNaoNecessario << " MT";
    cout << "\nTotal seguro no Cofre de Poupança: " << usuario.poupancaAcumulada << " MT";
    cout << "\nDias registados nesta sessao: " << dias;

    calcularIndiceFinanceiro();
    pausa();
}

void calcularIndiceFinanceiro() {
    float indice;
    float usado = usuario.rendaBase - usuario.saldoAtual;

    if(usuario.rendaBase == 0) {
        indice = 0;
    } else {
        indice = ((usuario.rendaBase - usado) / usuario.rendaBase) * 100;
    }

    cout << "\n\nIndice Financeiro: " << fixed << setprecision(2) << indice << "%";
    cout << "\nSituacao: ";

    if(indice >= 81) cout << "SAUDAVEL";
    else if(indice >= 61) cout << "ESTAVEL";
    else if(indice >= 41) cout << "RISCO";
    else cout << "CRITICA";
    cout << endl;
}

