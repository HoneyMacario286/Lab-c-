float calcularDespesasObrigatorias(bool ehCadastroInicial) {
    float total = 0;
    total += despesasFixas.mensalidade;
    total += despesasFixas.transporte;
    total += despesasFixas.alimentacao;
    total += despesasFixas.rendaCasa;
    total += despesasFixas.agua;
    total += despesasFixas.eletricidade;
    total += despesasFixas.internet;
    total += despesasFixas.outras;

    if (ehCadastroInicial) {
        usuario.saldoAtual = usuario.rendaBase - total;
    }

    cout << "\n==============================";
    cout << "\nRESUMO DAS OBRIGACOES";
    cout << "\n==============================";
    cout << "\nRenda Base: " << usuario.rendaBase << " MT";
    cout << "\nTotal de Despesas Obrigatorias: " << total << " MT";
    cout << "\nSaldo Disponivel Estimado: " << (usuario.rendaBase - total) << " MT\n";

    return total;
}

